{
  "name": "@dam-link/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "node --env-file=../../.env --watch --import tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../../.env dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src tests --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/s3-request-presigner": "3.668.0",
    "@dam-link/contracts": "workspace:*",
    "@fastify/cookie": "11.0.1",
    "@fastify/cors": "10.0.1",
    "@fastify/helmet": "12.0.1",
    "@fastify/multipart": "9.0.1",
    "@fastify/rate-limit": "10.1.1",
    "@fastify/sensible": "6.0.1",
    "@fastify/swagger": "9.2.0",
    "@fastify/swagger-ui": "5.1.0",
    "@sentry/node": "8.42.0",
    "@sentry/profiling-node": "8.42.0",
    "argon2": "0.41.1",
    "drizzle-orm": "0.36.1",
    "fastify": "5.1.0",
    "fastify-type-provider-zod": "4.0.1",
    "pino": "9.5.0",
    "postgres": "3.4.5",
    "sharp": "0.33.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.668.0",
    "@types/form-data": "2.5.2",
    "@types/node": "22.7.5",
    "@typescript-eslint/eslint-plugin": "8.11.0",
    "@typescript-eslint/parser": "8.11.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "0.28.0",
    "eslint": "9.13.0",
    "form-data": "4.0.1",
    "pino-pretty": "11.3.0",
    "tsx": "4.19.1",
    "typescript": "5.6.3",
    "vitest": "2.1.4"
  }
}
